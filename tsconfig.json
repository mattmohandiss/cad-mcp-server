{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "lib": ["ESNext"],
    "types": ["node"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "nodenext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true
  },
  "include": [
    "src/**/*",
    "eval/runner/**/*",
    "eval/generate/**/*",
    "tests/eval-logs/**/*",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "eval/generate/.venv", "eval/runner/.venv", "occt"]
}
