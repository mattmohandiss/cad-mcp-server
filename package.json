{
  "name": "cad-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for AI-assisted STEP CAD inspection, geometry queries, PMI hints, and revision comparison",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "node_modules/occt-wasm/dist",
    "node_modules/occt-wasm/package.json",
    "!dist/tests",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "docs/EXAMPLE_PROMPTS.md"
  ],
  "bin": {
    "cad-mcp-server": "dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "prettier --write src/",
    "lint": "eslint \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cad",
    "step",
    "stp",
    "mechanical-engineering",
    "manufacturing",
    "dfm",
    "gdandt",
    "pmi",
    "geometry",
    "opencascade",
    "occt",
    "wasm",
    "claude",
    "ai-tools"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/mattmohandiss/cad-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattmohandiss/cad-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/mattmohandiss/cad-mcp-server/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "occt-wasm": "file:./occt/ts",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "bundleDependencies": [
    "occt-wasm"
  ]
}
