{
  "name": "cad-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for CAD STEP file analysis",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "!dist/tests",
    "README.md"
  ],
  "bin": {
    "cad-mcp-server": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "prettier --write src/",
    "lint": "eslint \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "cad",
    "step"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "occt-wasm": "file:./vendor/occt-wasm/ts",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vitest": "^4.1.8"
  }
}
