{
  "name": "cad-mcp-server",
  "version": "0.3.3",
  "mcpName": "io.github.mattmohandiss/cad-mcp-server",
  "description": "MCP server for inspecting STEP CAD files -- extract faces, edges, mass properties, and PMI from 3D models via LLM tools, no CAD software needed.",
  "type": "module",
  "main": "dist/src/index.js",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "!dist/eval",
    "!dist/src/tests",
    "!dist/vitest.config.*",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "docs/EXAMPLE_PROMPTS.md",
    "server.json"
  ],
  "bin": {
    "cad-mcp-server": "dist/src/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "cpu": [
    "x64",
    "arm64"
  ],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "preferUnplugged": true,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write src/",
    "lint": "eslint \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.sh": [
      "bash -n"
    ]
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cad",
    "step",
    "stp",
    "3d",
    "mechanical-engineering",
    "manufacturing",
    "dfm",
    "gdandt",
    "pmi",
    "geometry",
    "inspection",
    "quality",
    "b-rep",
    "opencascade",
    "occt",
    "wasm",
    "claude",
    "ai-tools"
  ],
  "author": "Matt Mohandiss <mattmohandiss@gmail.com>",
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/mattmohandiss"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "homepage": "https://github.com/mattmohandiss/cad-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattmohandiss/cad-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/mattmohandiss/cad-mcp-server/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "occt-wasm": "file:./occt/ts",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-sdk/gateway": "^4.0.5",
    "@ai-sdk/mcp": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "ai": "^7.0.4",
    "eslint": "^10.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "bundleDependencies": [
    "occt-wasm"
  ]
}
